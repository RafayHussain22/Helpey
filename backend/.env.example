# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/helpey
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/helpey

# JWT (change this to a random 32+ character string)
JWT_SECRET=change-me-in-production-min-32-chars!

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (for embeddings)
OPENAI_API_KEY=

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# File uploads
UPLOADS_DIR=./uploads

# Celery
CELERY_BROKER_URL=sqla+sqlite:///celery.db
CELERY_RESULT_BACKEND=db+sqlite:///celery_results.db

# WorkOS SSO
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_ORGANIZATION_ID=
WORKOS_REDIRECT_URI=http://localhost:8000/api/auth/workos/callback

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
